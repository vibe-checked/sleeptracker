{
  "expo": {
    "name": "SleepTracker",
    "slug": "sleeptracker",
    "version": "1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sleeptracker",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "buildNumber": "2",
      "bundleIdentifier": "com.markutilitylabs.sleeptracker",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.markutilitylabs.sleeptracker",
      "adaptiveIcon": {
        "backgroundColor": "#060a18",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#060a18"
        }
      ],
      "expo-sharing",
      "expo-notifications",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "SleepTracker reads your sleep, heart rate, HRV, and respiratory data from Apple Health to show your nightly sleep analysis.",
          "NSHealthUpdateUsageDescription": "SleepTracker can save sample sleep sessions to Apple Health.",
          "background": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "SleepTracker uses the microphone overnight to detect snoring and room noise while you sleep. Audio is analyzed on-device and never recorded or uploaded."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
